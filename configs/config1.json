{
  "NAME": "Secure Config",
  "listen": "0.0.0.0",
  "port": 443,
  "sni": "www.cloudflare.com",
  "transport": {
    "type": "tls-ws",
    "path": "/.well-known/maxss",
    "alpn": [
      "http/1.1"
    ],
    "read_buffer_kb": 256,
    "write_buffer_kb": 256,
    "max_frame_kb": 128
  },
  "crypto": {
    "kdf": "hkdf-sha512",
    "key_exchange": "x25519",
    "aead_outer": "aes-256-gcm",
    "aead_inner": "xchacha20-poly1305",
    "integrity": "hmac-sha3-256",
    "mask": "blake2b-xor",
    "rekey_interval_frames": 4096
  },
  "obfuscation": {
    "padding_min": 32,
    "padding_max": 768,
    "jitter_ms": 2,
    "burst_padding": 2
  },
  "tls": {
    "cert_file": "",
    "key_file": "",
    "min_version": "1.3",
    "prefer_server_cipher": true,
    "session_tickets": true
  },
  "limits": {
    "handshake_timeout_sec": 10,
    "idle_timeout_sec": 180,
    "dial_timeout_sec": 10,
    "max_connections": 20000
  },
  "meta": {
    "profile": "maximum-stealth-speed"
  }
}
